# Root gitignore

# Environment files
**/.*env
**/.*env.local
**/.env.*
!**/.env.example

# Frontend (Node.js/Next.js)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts
frontend/coverage/
frontend/*.tsbuildinfo
frontend/*.pem
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.vercel/

# Backend (Python/Django)
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*.py[cod]
backend/*.egg-info/
backend/dist/
backend/build/
backend/*.egg
backend/*.sqlite3
backend/logs/
backend/*.log
backend/media/
backend/staticfiles/
backend/store/migrations/__pycache__/
backend/users/migrations/__pycache__/
backend/orders/migrations/__pycache__/
backend/api/migrations/__pycache__/

# IDEs and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
test_large_image.jpg
