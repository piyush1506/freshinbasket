# =============================================================================
# DJANGO SECURITY
# =============================================================================
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# =============================================================================
# DATABASE
# =============================================================================
DB_NAME=greenmart
DB_USER=greenmart_user
DB_PASSWORD=your-strong-password
DB_HOST=localhost
DB_PORT=5432

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379/1

# =============================================================================
# CLOUDINARY
# =============================================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# RAZORPAY
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
